<?js
var fs = this.fs;
var pathMod = this.pathModule;

var projectRoot = process.cwd();
var libDir = pathMod.join(projectRoot, 'lib', 'komps');
var iconsDir = pathMod.join(projectRoot, 'docs', 'images', 'icons');

// Resolve icon SVG for this doc based on its source file
var docIcon = '';
if (doc.meta && doc.meta.path && doc.meta.filename) {
    var relPath = pathMod.relative(libDir, doc.meta.path);
    var filename = doc.meta.filename.replace(/\.js$/, '');

    // Try exact filename first (e.g. auto-grid.svg for auto-grid.js)
    var iconPath = pathMod.join(iconsDir, filename + '.svg');

    // If not found and this is a child component, try the parent directory name
    // e.g. table/cell.js → table.svg
    if (!fs.existsSync(iconPath) && relPath && relPath !== '' && relPath !== '.') {
        var parentDir = relPath.split(pathMod.sep)[0];
        iconPath = pathMod.join(iconsDir, parentDir + '.svg');
    }

    if (fs.existsSync(iconPath)) {
        docIcon = fs.readFileSync(iconPath, 'utf8').replace('<svg ', '<svg class="doc-icon" ');
    }
}
?>
<article class="doc">
    <header>
        <h1>
            <?js if (docIcon) { ?>
                <?js= docIcon ?>
            <?js } else if (this.showKindIcons) { ?>
                <div class="kind kind-color kind-<?js= doc.kind ?>">
                    <span class="icon-kind icon-kind-<?js= doc.kind ?>"><?js= this.kindIcon(doc.kind) ?></span>
                    <?js= this.kindLabel(doc.kind, false) ?>
                </div>
            <?js } ?>
            <?js= this.partial('doc/signature.tmpl', {doc, constructor: false, augments: true }) ?>
        </h1>
    </header>

    <?js= this.partial('doc/details.tmpl', { doc, depth: 1 }) ?>
</article>
