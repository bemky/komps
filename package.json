{
  "name": "komps",
  "type": "module",
  "version": "1.0.0",
  "description": "Komps is a library of style-less Web Components for building UIs. Komps is platform-agnostic, and each component is fully tree-shakeable by any bundler.",
  "main": "lib/komps.js",
  "sideEffects": ["./lib/register-all.js"],
  "scripts": {
    "docs": "jsdoc -c jsdoc.json",
    "docs:watch": "npx nodemon --watch lib --watch docs-src --ext js,css,md,html --exec 'npm run docs'",
    "docs:serve": "npx serve docs",
    "demo": "node docs-src/demo/build.js",
    "test": "node --import ./test/register.js node_modules/.bin/mocha --config ./.mocha.yml"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bemky/komps.git"
  },
  "keywords": [
    "components",
    "elements",
    "ui"
  ],
  "author": "Ben Ehmke",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bemky/komps/issues"
  },
  "homepage": "https://github.com/bemky/komps#readme",
  "dependencies": {
    "@floating-ui/dom": "^1.5.2",
    "dolla": "github:bemky/dolla"
  },
  "devDependencies": {
    "highlight.js": "^11.11.1",
    "jsdoc": "^4.0.3",
    "jsdoc-export-default-interop": "^0.3.1",
    "jsdoc-press": "github:bemky/jsdoc-press",
    "jsdom": "^28.1.0",
    "jsdom-global": "^3.0.2",
    "mocha": "^11.7.5"
  }
}
