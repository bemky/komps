{
  "name": "komps",
  "type": "module",
  "version": "1.0.0",
  "description": "Komps is a library of style-less Web Components for building UIs. Komps is platform-agnostic, and each component is fully tree-shakeable by any bundler.",
  "main": "lib/komps.js",
  "exports": {
    ".": "./lib/komps.js",
    "./element": "./lib/komps/element.js",
    "./auto-grid": "./lib/komps/auto-grid.js",
    "./content-area": "./lib/komps/content-area.js",
    "./dropdown": "./lib/komps/dropdown.js",
    "./dropzone": "./lib/komps/dropzone.js",
    "./floater": "./lib/komps/floater.js",
    "./form": "./lib/komps/form.js",
    "./input": "./lib/komps/input.js",
    "./modal": "./lib/komps/modal.js",
    "./notification-center": "./lib/komps/notification-center.js",
    "./resizer": "./lib/komps/resizer.js",
    "./search-field": "./lib/komps/search-field.js",
    "./select": "./lib/komps/select.js",
    "./spreadsheet": "./lib/komps/spreadsheet.js",
    "./table": "./lib/komps/table.js",
    "./tooltip": "./lib/komps/tooltip.js",
    "./plugins": "./lib/komps/plugins.js",
    "./support": "./lib/support.js"
  },
  "scripts": {
    "docs": "jsdoc -c jsdoc.json",
    "docs:watch": "npx nodemon --watch lib --watch docs --ext js,css,md,html --exec 'npm run docs'",
    "docs:serve": "npx serve _docs",
    "demo": "node docs/demo/build.js",
    "test": "node --import ./test/register.js node_modules/.bin/mocha --config ./.mocha.yml"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bemky/komps.git"
  },
  "keywords": [
    "components",
    "elements",
    "ui"
  ],
  "author": "Ben Ehmke",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bemky/komps/issues"
  },
  "homepage": "https://github.com/bemky/komps#readme",
  "dependencies": {
    "@floating-ui/dom": "^1.5.2",
    "dolla": "github:bemky/dolla"
  },
  "devDependencies": {
    "highlight.js": "^11.11.1",
    "jsdoc": "^4.0.3",
    "jsdoc-export-default-interop": "^0.3.1",
    "jsdoc-press": "github:bemky/jsdoc-press",
    "jsdom": "^28.1.0",
    "jsdom-global": "^3.0.2",
    "mocha": "^11.7.5"
  }
}
